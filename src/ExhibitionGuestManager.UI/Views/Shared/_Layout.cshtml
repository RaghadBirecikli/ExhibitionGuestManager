@using System.Globalization
@inject IStringLocalizer<SharedResource> L

@{
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = currentCulture == "ar";
    var htmlLang = isArabic ? "ar" : "en";
    var htmlDir = isArabic ? "rtl" : "ltr";
    var bootstrapCss = isArabic
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="@htmlLang" dir="@htmlDir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["AppName"]</title>
    <link href="@bootstrapCss" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container app-navbar-container">
            <a class="navbar-brand d-flex align-items-center gap-3" asp-controller="Home" asp-action="Index">
                <span class="navbar-logo-wrap">
                    <img src="~/images/logo.png" alt="@L["AppName"]" class="navbar-logo" onerror="this.style.display='none'; this.parentElement.classList.add('logo-missing');" />
                </span>
                <span class="brand-copy">
                    <span class="brand-kicker">EGM</span>
                    <span class="brand-title">@L["AppName"]</span>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2 nav-cluster">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-link-main" href="/Customers">@L["Customers"]</a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm nav-action-btn">@L["Logout"]</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-light btn-sm nav-action-btn" asp-controller="Account" asp-action="Login">@L["Login"]</a>
                        </li>
                    }
                    <li class="nav-item">
                        <div class="language-switcher" role="group" aria-label="Language switcher">
                            <form asp-controller="Account" asp-action="SetLanguage" method="post" class="d-inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="culture" value="ar" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-sm language-btn @(isArabic ? "language-btn-active" : "language-btn-inactive")">@L["LanguageArabic"]</button>
                            </form>
                            <form asp-controller="Account" asp-action="SetLanguage" method="post" class="d-inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="culture" value="en" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-sm language-btn @(!isArabic ? "language-btn-active" : "language-btn-inactive")">@L["LanguageEnglish"]</button>
                            </form>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="app-main">
        <div class="container">
            @if (TempData["Success"] is string successMessage)
            {
                <div class="alert alert-success alert-dismissible fade show app-alert" role="alert">
                    @successMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] is string errorMessage)
            {
                <div class="alert alert-danger alert-dismissible fade show app-alert" role="alert">
                    @errorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    </div>
</body>
</html>
