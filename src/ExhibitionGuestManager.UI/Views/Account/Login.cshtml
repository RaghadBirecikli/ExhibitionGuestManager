@model LoginViewModel
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["LoginTitle"];
    Layout = "_Layout";
}

<div class="auth-shell">
    <div class="auth-card card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="auth-header text-center mb-4 mb-md-5">
                <div class="auth-logo-wrap mx-auto mb-3">
                    <img src="~/images/logo.png" alt="@L["AppName"]" class="auth-logo" onerror="this.style.display='none'; this.parentElement.classList.add('logo-missing');" />
                </div>
                <span class="auth-kicker d-inline-block mb-2">EGM</span>
                <h1 class="h3 fw-semibold mb-2">@L["LoginTitle"]</h1>
                <p class="auth-subtitle mb-0">@L["LoginSubtitle"]</p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" novalidate class="auth-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger app-alert" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control form-control-lg auth-input" autocomplete="username" autofocus />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control form-control-lg auth-input" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check auth-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 auth-submit">@L["SignIn"]</button>

                <p class="small text-secondary text-center mt-4 mb-0 auth-demo">
                    @L["DemoCredentials"]: <span class="fw-medium">admin@example.com</span> / <span class="fw-medium">Admin@12345</span>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
