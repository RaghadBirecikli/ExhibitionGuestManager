@model CustomerDetailsViewModel
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["DeleteCustomer"];
}

<div class="mb-4">
    <h1 class="h3 fw-semibold mb-1">@L["DeleteCustomer"]</h1>
    <p class="text-secondary mb-0">@L["DeleteCustomerSubtitle"]</p>
</div>

<section class="content-panel">
    <div class="alert alert-warning app-alert delete-alert" role="alert">
        @L["DeleteWarning"]
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="detail-label">@L["Name"]</div>
            <div class="detail-value">@Model.Name</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["MobileNumber"]</div>
            <div class="detail-value">@Model.MobileNumber</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["OrganizationName"]</div>
            <div class="detail-value">@(Model.OrganizationName ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["City"]</div>
            <div class="detail-value">@(Model.City ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["Email"]</div>
            <div class="detail-value">@(Model.Email ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["Interests"]</div>
            @if (Model.Interests.Count == 0)
            {
                <div class="detail-value">-</div>
            }
            else
            {
                <div class="interest-badges">
                    @foreach (var interest in Model.Interests)
                    {
                        <span class="badge rounded-pill text-bg-light interest-badge">@L[interest]</span>
                    }
                </div>
            }
        </div>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex flex-wrap gap-2">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">@L["ConfirmDelete"]</button>
        <a asp-action="Index" class="btn btn-outline-secondary">@L["Cancel"]</a>
    </form>
</section>
