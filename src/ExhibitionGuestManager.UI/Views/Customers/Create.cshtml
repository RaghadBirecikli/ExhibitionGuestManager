@model CustomerCreateViewModel
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["CreateCustomer"];
    var titleOptions = new[] { "MrMrs", "Teacher", "Doctor", "Other" };
    var interestOptions = new[]
    {
        "CurriculumBooks",
        "TrainingKits",
        "RoboticsLab",
        "ProfessionalExamPreparationCourses",
        "EnglishExamPreparationCourses",
        "BilingersBilingualKindergartenProgram",
        "TeacherTrainingWorkshops",
        "AfterSchoolMentalArithmeticProgram",
        "AfterSchoolProgramsPackage",
        "ArticRobots",
        "ACEBOTTRobots",
        "HelloCodeProgrammingProgram",
        "OtherInterest"
    };
}

<div class="d-flex align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 fw-semibold mb-1">@L["CreateCustomer"]</h1>
        <p class="text-secondary mb-0">@L["CreateCustomerSubtitle"]</p>
    </div>
</div>

<section class="content-panel">
    <form asp-action="Create" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-alert" role="alert"></div>

        <div class="col-12">
            <h2 class="h5 fw-semibold mb-0">@L["BasicInformation"]</h2>
        </div>

        <div class="col-md-6">
            <label asp-for="Title" class="form-label"></label>
            <select asp-for="Title" class="form-select">
                <option value="">@L["Select"]</option>
                @foreach (var title in titleOptions)
                {
                    <option value="@title">@L[title]</option>
                }
            </select>
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Position" class="form-label"></label>
            <input asp-for="Position" class="form-control" />
            <span asp-validation-for="Position" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="MobileNumber" class="form-label"></label>
            <input asp-for="MobileNumber" class="form-control" inputmode="numeric" maxlength="10" pattern="[0-9]{10}" autocomplete="tel" />
            <span asp-validation-for="MobileNumber" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" />
            <span asp-validation-for="City" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="OrganizationName" class="form-label"></label>
            <input asp-for="OrganizationName" class="form-control" />
            <span asp-validation-for="OrganizationName" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <h2 class="h5 fw-semibold mb-2">@L["Interests"]</h2>
            <div class="interests-grid">
                @foreach (var interest in interestOptions)
                {
                    var id = $"interest-{interest}";
                    <div class="form-check interest-option">
                        <input class="form-check-input" type="checkbox" id="@id" name="Interests" value="@interest" checked="@Model.Interests.Contains(interest)" />
                        <label class="form-check-label" for="@id">@L[interest]</label>
                    </div>
                }
            </div>
            <span asp-validation-for="Interests" class="text-danger small"></span>
        </div>

        <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">@L["Save"]</button>
            <a asp-action="Index" class="btn btn-outline-secondary">@L["BackToList"]</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
