@model CustomerDetailsViewModel
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["CustomerDetails"];
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 fw-semibold mb-1">@Model.Name</h1>
        <p class="text-secondary mb-0">@L["CustomerDetails"]</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">@L["Edit"]</a>
        <a asp-action="Index" class="btn btn-outline-secondary">@L["BackToList"]</a>
    </div>
</div>

<section class="content-panel">
    <div class="row g-4 details-grid">
        <div class="col-md-6">
            <div class="detail-label">@L["Title"]</div>
            <div class="detail-value">@(string.IsNullOrWhiteSpace(Model.Title) ? "-" : L[Model.Title])</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["Name"]</div>
            <div class="detail-value">@Model.Name</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["Position"]</div>
            <div class="detail-value">@(Model.Position ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["MobileNumber"]</div>
            <div class="detail-value">@Model.MobileNumber</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["City"]</div>
            <div class="detail-value">@(Model.City ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["OrganizationName"]</div>
            <div class="detail-value">@(Model.OrganizationName ?? "-")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">@L["Email"]</div>
            <div class="detail-value">@(Model.Email ?? "-")</div>
        </div>
        <div class="col-12">
            <div class="detail-label">@L["Interests"]</div>
            @if (Model.Interests.Count == 0)
            {
                <div class="detail-value">-</div>
            }
            else
            {
                <div class="interest-badges">
                    @foreach (var interest in Model.Interests)
                    {
                        <span class="badge rounded-pill text-bg-light interest-badge">@L[interest]</span>
                    }
                </div>
            }
        </div>
        <div class="col-md-3">
            <div class="detail-label">@L["CreatedAt"]</div>
            <div class="detail-value">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        </div>
        <div class="col-md-3">
            <div class="detail-label">@L["CreatedBy"]</div>
            <div class="detail-value">@(Model.CreatedBy ?? "-")</div>
        </div>
        <div class="col-md-3">
            <div class="detail-label">@L["UpdatedAt"]</div>
            <div class="detail-value">@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
        </div>
        <div class="col-md-3">
            <div class="detail-label">@L["UpdatedBy"]</div>
            <div class="detail-value">@(Model.UpdatedBy ?? "-")</div>
        </div>
    </div>
</section>
